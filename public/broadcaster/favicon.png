@import url('https://fonts.googleapis.com/css2?family=Roboto+Slab&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #111;
  --s1:      #181818;
  --s2:      #1e1e1e;
  --s3:      #242424;
  --border:  #2c2c2c;
  --border2: #383838;
  --text:    #e2e2e2;
  --muted:   #666;
  --green:   #22c55e;
  --amber:   #f59e0b;
  --red:     #ef4444;
  --blue:    #38bdf8;
  --mono: "Roboto Slab", serif;
}

html, body {
  background: var(--bg);
  color: var(--text);
  font-family: "Roboto Slab", serif;
}

.app { max-width: 1440px; margin: 0 auto; padding: 12px 16px 40px; }

/* ── TOPBAR ── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding-bottom: 10px; border-bottom: 1px solid var(--border); margin-bottom: 12px;
}
.topbar h1 { font-family: var(--mono); font-size: 15px; letter-spacing: .12em; color: var(--red); font-weight: 400; }
.topbar-sub { font-size: 10px; color: var(--muted); letter-spacing: .15em; margin-top: 2px; }
.topbar-right { display: flex; align-items: center; gap: 14px; }
.clock { font-family: var(--mono); font-size: 18px; color: var(--green); letter-spacing: .08em; }

.live-badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: 3px; font-size: 11px; font-weight: 600;
  letter-spacing: .12em; border: 1px solid; font-family: var(--mono);
}
.live-badge.off { background: rgba(255,255,255,.03); border-color: var(--border2); color: var(--muted); }
.live-badge.on  { background: rgba(239,68,68,.1); border-color: var(--red); color: var(--red); }
.live-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
.live-badge.on .live-dot { animation: blink .9s ease-in-out infinite; }
@keyframes blink { 50% { opacity: .2; } }

/* ── GRID ── */
.grid { display: grid; grid-template-columns: 1fr 320px; gap: 12px; align-items: start; }
@media (max-width: 960px) { .grid { grid-template-columns: 1fr; } }

/* ── PREVIEW ── */
.preview-box { background: var(--s1); border: 1px solid var(--border); border-radius: 6px; padding: 10px; }
.section-label { font-size: 10px; color: var(--muted); letter-spacing: .2em; text-transform: uppercase; margin-bottom: 8px; }
.canvas-wrap { position: relative; aspect-ratio: 16/9; background: #000; border-radius: 4px; overflow: hidden; }
#outCanvas { display: block; width: 100%; height: 100%; }
#camVideo  { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
.src-badge { position: absolute; top: 8px; left: 8px; font-family: var(--mono); font-size: 10px; padding: 3px 7px; background: rgba(0,0,0,.75); border: 1px solid var(--border2); border-radius: 2px; color: var(--amber); letter-spacing: .08em; }
.preview-meta { display: flex; align-items: center; justify-content: space-between; margin-top: 8px; font-size: 11px; color: var(--muted); font-family: var(--mono); }
.preview-meta span { color: var(--green); }

.vu-wrap { display: flex; align-items: center; gap: 8px; background: var(--s1); border: 1px solid var(--border); border-radius: 4px; padding: 6px 10px; margin-top: 8px; }
.vu-lbl { font-size: 10px; color: var(--muted); letter-spacing: .15em; font-family: var(--mono); flex-shrink: 0; }
#vuBars { flex: 1; display: flex; gap: 2px; align-items: flex-end; height: 28px; }
.vu-bar { flex: 1; min-height: 2px; background: var(--green); border-radius: 1px; transition: height .05s; }
.vu-bar.a { background: var(--amber); }
.vu-bar.r { background: var(--red); }
#vuDb { font-family: var(--mono); font-size: 10px; color: var(--muted); min-width: 34px; text-align: right; }
.ledbar-wrap { display: flex; gap: 2px; margin-top: 6px; }
#ledbar { display: flex; gap: 2px; flex: 1; }
.ls { flex: 1; height: 5px; background: var(--border); border-radius: 1px; }
.ls.ag { background: var(--green); }
.ls.aa { background: var(--amber); }
.ls.ar { background: var(--red); }

/* ── CHANNEL + GOLIVE ── */
.go-live-box { background: var(--s1); border: 1px solid var(--border); border-radius: 6px; padding: 10px; margin-top: 10px; }

/* ── SIDEBAR ── */
.sidebar { display: flex; flex-direction: column; gap: 8px; }

/* ── CARD ── */
.card { background: var(--s1); border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px; }
.card-title { font-size: 10px; color: var(--muted); letter-spacing: .2em; text-transform: uppercase; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
.card-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.ctdot { width: 5px; height: 5px; border-radius: 50%; background: var(--amber); flex-shrink: 0; }

/* ── FORM ── */
label { display: block; font-size: 11px; color: var(--muted); letter-spacing: .06em; margin-top: 8px; margin-bottom: 3px; }
label:first-child { margin-top: 0; }
label.chk { display: flex !important; align-items: center; gap: 6px; color: var(--text) !important; cursor: pointer; font-size: 12px !important; margin-top: 6px; }

input[type=text], input[type=number], select, textarea {
  width: 100%; background: #0d0d0d; border: 1px solid var(--border2); border-radius: 3px;
  color: var(--text); font-family: var(--mono); font-size: 12px; padding: 6px 8px; outline: none;
}
input[type=text]:focus, input[type=number]:focus, select:focus { border-color: var(--green); }
select option { background: #111; }
textarea { resize: vertical; min-height: 52px; font-size: 11px; }
input[type=range] { width: 100%; accent-color: var(--green); cursor: pointer; }
input[type=checkbox] { accent-color: var(--green); width: 13px; height: 13px; flex-shrink: 0; cursor: pointer; }
input[type=file] { font-size: 11px; color: var(--muted); cursor: pointer; width: 100%; }

.rrow { display: flex; align-items: center; gap: 6px; }
.rrow input[type=range] { flex: 1; }
.rval { font-family: var(--mono); font-size: 11px; color: var(--green); min-width: 36px; text-align: right; }

/* ── BUTTONS ── */
.btn-row { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
button { cursor: pointer; font-family: var(--mono); font-size: 11px; letter-spacing: .08em; border-radius: 3px; padding: 6px 12px; border: 1px solid; transition: background .12s, opacity .12s; }
.btn-go   { background: rgba(34,197,94,.12); border-color: #166534; color: var(--green); }
.btn-go:hover:not(:disabled)   { background: rgba(34,197,94,.24); }
.btn-stop { background: rgba(239,68,68,.1);  border-color: #7f1d1d; color: var(--red); }
.btn-stop:hover:not(:disabled) { background: rgba(239,68,68,.22); }
.btn-ghost { background: transparent; border-color: var(--border2); color: var(--muted); }
.btn-ghost:hover { color: var(--text); border-color: var(--text); }
.btn-warn { background: rgba(245,158,11,.1); border-color: #78350f; color: var(--amber); }
.btn-warn:hover:not(:disabled) { background: rgba(245,158,11,.22); }
.btn-blue { background: rgba(56,189,248,.08); border-color: #075985; color: var(--blue); }
.btn-blue:hover:not(:disabled) { background: rgba(56,189,248,.18); }
button:disabled { opacity: .3; cursor: not-allowed; }

/* ── SOURCE TABS ── */
.src-tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-bottom: 10px; }
.src-tab { padding: 6px; text-align: center; font-size: 11px; letter-spacing: .06em; background: #0d0d0d; border: 1px solid var(--border2); color: var(--muted); cursor: pointer; border-radius: 3px; transition: all .12s; font-family: var(--mono); }
.src-tab.active { border-color: var(--amber); color: var(--amber); background: rgba(245,158,11,.08); }

/* ── PLAYLIST ── */
.playlist { border: 1px solid var(--border); border-radius: 3px; background: #0d0d0d; max-height: 148px; overflow-y: auto; }
.playlist::-webkit-scrollbar { width: 4px; }
.playlist::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
.pl-item { display: flex; align-items: center; gap: 6px; padding: 5px 8px; border-bottom: 1px solid var(--border); cursor: pointer; font-size: 11px; transition: background .1s; }
.pl-item:last-child { border-bottom: none; }
.pl-item:hover { background: rgba(255,255,255,.03); }
.pl-item.playing { background: rgba(34,197,94,.07); color: var(--green); }
.pl-ic { font-size: 10px; width: 12px; flex-shrink: 0; color: var(--muted); }
.pl-item.playing .pl-ic { color: var(--green); }
.pl-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--mono); }
.pl-dur { color: var(--muted); font-size: 10px; flex-shrink: 0; font-family: var(--mono); }
.pl-del { color: var(--muted); font-size: 10px; flex-shrink: 0; padding: 0 2px; }
.pl-del:hover { color: var(--red); }
.pl-empty { padding: 10px; text-align: center; color: var(--muted); font-size: 11px; }

.seek-wrap { margin-top: 6px; }
input.seek { width: 100%; accent-color: var(--amber); }
.time-row { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 2px; }
.pb-row { display: flex; gap: 4px; align-items: center; margin-top: 6px; flex-wrap: wrap; }
.pb-row label.chk { margin-top: 0; font-size: 11px !important; }

.hint { font-size: 10px; color: var(--muted); margin-top: 6px; line-height: 1.5; }

/* ── URGENT CARD ── */
.urgent-card { border-color: #3f1515; }
